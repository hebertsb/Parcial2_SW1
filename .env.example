# ============================================================
# NexusFlow-AI — Plantilla de variables de entorno
# Copiar como .env y rellenar con valores reales
# NUNCA subir el archivo .env al repositorio
# ============================================================



# ---- Correo SMTP (Gmail) ----
# App Password en: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ---- Storage ----
STORAGE_LOCATION=/app/evidencias

# ---- FastAPI (nombre del servicio Docker interno) ----
FASTAPI_URL=http://fastapi-service:8000

# ---- Groq API (gratis) ----
# Obtener en: https://console.groq.com → API Keys
OPENAI_API_KEY=gsk_...
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
WHISPER_MODEL=whisper-large-v3

# ---- Modo de IA ----
# "api" = usa OpenAI (requiere OPENAI_API_KEY válida)
# "local" = modo offline sin API externa
AI_MODE=api

# ---- CORS ----
# FastAPI CORS (separar con coma)
CORS_ORIGINS=http://localhost

# Spring Boot CORS (separar con coma, sin espacios)
# Agregar aqui la URL del frontend en produccion
# Ejemplo EC2/Cloudflare: https://tu-url.trycloudflare.com,http://localhost:4200
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
