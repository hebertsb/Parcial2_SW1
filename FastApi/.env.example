# ============================================================
# NexusFlow AI - Configuración de Entorno
# ============================================================

# ---- OpenAI API ----
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modelo GPT para generación de diagramas y asistente
OPENAI_MODEL=gpt-4o-mini

# Modelo Whisper para transcripción de voz
WHISPER_MODEL=whisper-1

# ---- Servidor ----
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---- Spring Boot Backend ----
SPRING_BOOT_URL=http://localhost:8080

# ---- CORS ----
# Separar orígenes con coma: http://localhost:4200,http://localhost:3000
CORS_ORIGINS=*

# ---- Modo de operación ----
# "api" = Usa OpenAI API (requiere OPENAI_API_KEY)
# "local" = Usa plantillas locales sin API (modo offline)
AI_MODE=api
