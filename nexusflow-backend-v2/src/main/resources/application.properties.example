# ====================================================
# application.properties.example
# Copiar como application.properties y rellenar los valores reales
# NUNCA subir application.properties al repositorio
# ====================================================

server.port=${SERVER_PORT:9090}
spring.data.mongodb.uri=${MONGODB_URI:mongodb://127.0.0.1:27017/nexusflow_oficial}

# JWT — Cambiar por una clave segura de al menos 32 caracteres
jwt.secret=${JWT_SECRET:CAMBIA-ESTA-CLAVE-POR-UNA-SEGURA-32CHARS}
jwt.expiration=36000000

# Gmail SMTP — Usar App Password de Google (no la contraseña normal)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:tu-email@gmail.com}
spring.mail.password=${MAIL_PASSWORD:tu-app-password-de-16-caracteres}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Ruta local para guardar archivos (CU-15)
storage.location=${STORAGE_LOCATION:C:/ruta/a/tu/carpeta/evidencias}
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

logging.level.org.springframework.web=info
spring.jackson.date-format=yyyy-MM-dd HH:mm:ss

# URL del microservicio FastAPI
fastapi.url=${FASTAPI_URL:http://localhost:8000}
fastapi.timeout=30000
